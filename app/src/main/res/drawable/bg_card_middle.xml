<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <stroke
                android:width="0.8dp"
                android:color="@color/nftBorder" />
        </shape>
    </item>

    <item
        android:gravity="top"
        android:left="1dp"
        android:right="1dp">
        <shape>
            <size android:height="1dp" />
            <solid android:color="?attr/bg_white" />
        </shape>
    </item>

    <item
        android:gravity="bottom"
        android:left="1dp"
        android:right="1dp">
        <shape>
            <size android:height="1dp" />
            <solid android:color="?attr/bg_white" />
        </shape>
    </item>
</layer-list>
