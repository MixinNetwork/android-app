<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/market_watchlist_compact_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_market_watchlist_widget_card"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/market_watchlist_compact_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/Watchlist"
            android:textColor="@color/textPrimary"
            android:textSize="12sp" />

        <ImageView
            android:id="@+id/market_watchlist_compact_app_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            android:src="@mipmap/ic_launcher" />

    </LinearLayout>

    <ListView
        android:id="@+id/market_watchlist_compact_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:divider="@color/divider"
        android:dividerHeight="0.5dp"
        android:scrollbars="vertical" />

    <TextView
        android:id="@+id/market_watchlist_compact_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="16dp"
        android:text="@string/watchlist_empty"
        android:textColor="@color/textAssist"
        android:textSize="13sp"
        android:visibility="gone" />

</LinearLayout>
