<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    android:background="@drawable/bg_round_8_border"
    android:minHeight="72dp"
    android:padding="12dp">

    <one.mixin.android.widget.CircleImageView
        android:id="@+id/icon_iv"
        android:layout_width="32dp"
        android:layout_height="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@drawable/ic_avatar_place_holder" />

    <TextView
        android:id="@+id/symbol_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="?attr/text_primary"
        android:textSize="15sp"
        app:layout_constraintStart_toEndOf="@id/icon_iv"
        app:layout_constraintTop_toTopOf="@id/icon_iv"
        tools:text="BTC" />

    <TextView
        android:id="@+id/leverage_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:background="@drawable/bg_round_4_solid_light_gray"
        android:includeFontPadding="false"
        android:paddingHorizontal="3dp"
        android:paddingVertical="1dp"
        android:textColor="?attr/text_assist"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="@id/symbol_tv"
        app:layout_constraintStart_toEndOf="@id/symbol_tv"
        app:layout_constraintTop_toTopOf="@id/symbol_tv"
        tools:text="10x" />

    <TextView
        android:id="@+id/change_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="@id/symbol_tv"
        app:layout_constraintTop_toBottomOf="@id/symbol_tv"
        tools:text="+1.9%"
        tools:textColor="@color/wallet_green" />

    <ImageView
        android:id="@+id/selected_iv"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/ic_asset_favorites"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="ContentDescription" />

</androidx.constraintlayout.widget.ConstraintLayout>
